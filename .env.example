# Vercel Postgres auto-injects POSTGRES_URL into the project once you create
# the database in the Storage tab. You only need to set the four below.
#
# Copy to .env.local for dev (after `vercel env pull` to grab POSTGRES_URL too).
# .env, .env.local, .env.production are gitignored — never commit them.

POSTGRES_URL=postgres://user:pass@host:5432/dbname?sslmode=require
ADMIN_USER=admin
ADMIN_PASS=admin123
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
